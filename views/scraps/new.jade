extends ../layout

block content
  h2 Scrap Asset

  if success
    .alert.alert-success= success
  if error
    .alert.alert-danger= error

  .card
    .card-body
      if assets && assets.length
        form(method='POST', action='/scraps')
          .row
            .col-md-6.mb-3
              label.form-label(for='asset_id') Asset *
              select.form-select#asset_id(name='asset_id', required)
                option(value='') Select Asset
                each asset in assets
                  option(value=asset.id) #{asset.serial_number} - #{asset.name} (#{asset.category ? asset.category.name : ''}) [#{asset.status}]
            .col-md-6.mb-3
              label.form-label(for='scrap_date') Scrap Date *
              input.form-control#scrap_date(type='date', name='scrap_date', required)
          .row
            .col-md-6.mb-3
              label.form-label(for='reason') Reason
              textarea.form-control#reason(name='reason', rows='2')
            .col-md-6.mb-3
              label.form-label(for='notes') Notes
              textarea.form-control#notes(name='notes', rows='2')
          .mt-3
            button.btn.btn-danger(type='submit')
              i.bi.bi-trash.me-1
              | Scrap Asset
      else
        .alert.alert-info No assets available to scrap
