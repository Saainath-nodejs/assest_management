doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title KT Asset Management
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css')
    link(rel='stylesheet', href='https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css')
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css')
    link(rel='stylesheet', href='/css/style.css')
  body
    if currentUser
      nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
        .container-fluid
          a.navbar-brand(href='/assets') KT Asset Management
          .navbar-nav.ms-auto
            span.navbar-text.me-3
              i.bi.bi-person-circle.me-1
              = currentUser.name
            a.nav-link(href='/logout')
              i.bi.bi-box-arrow-right.me-1
              | Logout

      .container-fluid
        .row
          nav.col-md-2.sidebar.bg-light.min-vh-100.pt-3
            ul.nav.flex-column
              li.nav-item
                a.nav-link(href='/employees')
                  i.bi.bi-people.me-2
                  | Employees
              li.nav-item
                a.nav-link(href='/categories')
                  i.bi.bi-tags.me-2
                  | Categories
              li.nav-item
                a.nav-link(href='/assets')
                  i.bi.bi-box-seam.me-2
                  | Assets
              li.nav-item
                a.nav-link(href='/reports/stock')
                  i.bi.bi-clipboard-data.me-2
                  | Stock View
              li.nav-item.mt-2
                small.text-muted.ps-3 OPERATIONS
              li.nav-item
                a.nav-link(href='/assignments/issue')
                  i.bi.bi-arrow-right-circle.me-2
                  | Issue Asset
              li.nav-item
                a.nav-link(href='/assignments/return')
                  i.bi.bi-arrow-left-circle.me-2
                  | Return Asset
              li.nav-item
                a.nav-link(href='/scraps/new')
                  i.bi.bi-trash.me-2
                  | Scrap Asset
              li.nav-item.mt-2
                small.text-muted.ps-3 REPORTS
              li.nav-item
                a.nav-link(href='/reports/asset-history')
                  i.bi.bi-clock-history.me-2
                  | Asset History

          main.col-md-10.p-4
            block content

    else
      block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')
    script(src='https://code.jquery.com/jquery-3.7.0.min.js')
    script(src='https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js')
    script(src='https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js')
    script(src='/js/app.js')
    block scripts
