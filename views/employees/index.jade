extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2 Employees
    a.btn.btn-primary(href='/employees/add')
      i.bi.bi-plus-lg.me-1
      | Add Employee

  .card.mb-3
    .card-body
      form.row.g-3(method='GET', action='/employees')
        .col-md-3
          select.form-select(name='status')
            option(value='all', selected=(filters.status === 'all' || !filters.status)) All Status
            option(value='active', selected=(filters.status === 'active')) Active
            option(value='inactive', selected=(filters.status === 'inactive')) Inactive
        .col-md-6
          input.form-control(type='text', name='search', placeholder='Search by name, code, email, department...', value=(filters.search || ''))
        .col-md-3
          button.btn.btn-outline-primary.w-100(type='submit') Filter

  if error
    .alert.alert-danger= error

  table.table.table-striped.table-hover#employeeTable
    thead
      tr
        th Code
        th Name
        th Email
        th Phone
        th Department
        th Designation
        th Branch
        th Status
        th Actions
    tbody
      each employee in employees
        tr
          td= employee.employee_code
          td= employee.name
          td= employee.email
          td= employee.phone
          td= employee.department
          td= employee.designation
          td= employee.branch
          td
            if employee.status === 'active'
              span.badge.bg-success Active
            else
              span.badge.bg-secondary Inactive
          td
            a.btn.btn-sm.btn-info.me-1(href='/employees/' + employee.id)
              i.bi.bi-eye
            a.btn.btn-sm.btn-warning(href='/employees/' + employee.id + '/edit')
              i.bi.bi-pencil

block scripts
  script.
    $(document).ready(function() {
      $('#employeeTable').DataTable({
        pageLength: 25,
        order: [[1, 'asc']]
      });
    });
